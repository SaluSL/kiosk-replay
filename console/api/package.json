{
  "name": "api",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "db:schema:auth": "bunx --bun auth@latest generate --output ./src/lib/database/schema/auth.ts --yes",
    "db:generate": "bunx --bun drizzle-kit generate --name",
    "db:migrate": "bun run src/lib/database/migrate.ts",
    "create:superuser": "bun run src/lib/commands/create-superuser.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@hono/zod-validator": "^0.7.6",
    "@rrweb/types": "^2.0.0-alpha.20",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rcmade/hono-docs": "^1.0.32",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  }
}
